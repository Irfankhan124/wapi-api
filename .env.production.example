# =============================
# WAPI API PRODUCTION ENV
# Copy this file to .env and fill real values.
# =============================
NODE_ENV=production
PORT=5000

# Your API public URL/domain
APP_URL=https://api.yourdomain.com
SERVER_ADDR=https://api.yourdomain.com
FRONTEND_URL=https://wapi-docs.pages.dev

# Use your real frontend/admin domains here. Separate with commas.
ALLOWED_ORIGINS=https://wapi-admin.pages.dev,https://wapi-docs.pages.dev,https://wapi-admin.web.app,https://wapi-docs.web.app,http://localhost:3000,http://localhost:3001

# Database
# If using this docker-compose file, keep these values:
MONGO_URI=mongodb://mongo:27017/wapi
MONGODB_URI=mongodb://mongo:27017/wapi
# If using MongoDB Atlas, use mongodb+srv://... instead.

# Redis / queues
# If using this docker-compose file, keep this value:
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Security - CHANGE THESE BEFORE PRODUCTION
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET
ENCRYPTION_KEY=CHANGE_THIS_32_CHARACTERS_LONG!!

# First admin created by seed script
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# WhatsApp / Meta webhook verify token
WHATSAPP_VERIFY_TOKEN=change_this_verify_token
FACEBOOK_LEAD_WEBHOOK_VERIFY_TOKEN=change_this_facebook_lead_token

# Email/SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=WAPI
MAIL_FROM_EMAIL=no-reply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/google/callback

# App install/license fields from original project
APP_ID=VVlHTldWMk4wSQ==
DOTENV_EDIT=true
MAINTENANCE_MODE=false

# Persistent Baileys credentials. On Render use /var/data/baileys-sessions.
BAILEYS_SESSION_DIR=./storage/sessions/baileys

# Server-to-server sends from the connected ISP database should not be blocked by UI conversation quotas.
WAPI_API_KEY_BYPASS_CONVERSATION_LIMIT=true
# Recipient addressing and paced multi-number sending.
WAPI_DEFAULT_COUNTRY_CODE=93
BAILEYS_SEND_DELAY_MS=650

